@{
}
@model StudentPortal.Web.Models.AddStudentViweModel


<h1>Add Student</h1>

<form asp-controller="Student" asp-action="Add" method="post">
    

<div class="mt-3">
    <label class="form-label">Name</label>
    <input type="text" class="form-control" asp-for="Name"/>
</div>
<div class="mt-3">
    <label class="form-label">Email</label>
    <input type="text" class="form-control" asp-for="email" />
</div>
<div class="mt-3">
    <label class="form-label">Phone</label>
    <input type="text" class="form-control" asp-for="phone" />
</div>

<div class="mt-3">
    <input type="checkbox" class="form-check-input" id="Subscribed" asp-for="Subscribed" />
    <lebel class="from-check-lebel" formaction="Subscribed">Subscribed</lebel>
</div>

<div class="mt-3">
    <button type="submit" class="btn btn-primary">Save</button>
</div>

</form>